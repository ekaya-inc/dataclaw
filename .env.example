# DataClaw runtime configuration
#
# This file is documentation only. DataClaw does not auto-load dotenv files.
# Copy the lines you want into your shell profile or another sourced file,
# then remove the leading "# " before sourcing.

# Bind address for the local HTTP server.
# Default: 127.0.0.1
# Note: v1 normalizes any value back to loopback.
# export DATACLAW_BIND_ADDR=127.0.0.1

# Preferred HTTP port. If busy, DataClaw increments to the next free port.
# Default: 18790
# export DATACLAW_PORT=18790

# Base data directory for local DataClaw state.
# Default: ~/.dataclaw
# export DATACLAW_DATA_DIR="$HOME/.dataclaw"

# SQLite metadata database path.
# Default: $DATACLAW_DATA_DIR/dataclaw.sqlite
# export DATACLAW_DB_PATH="$HOME/.dataclaw/dataclaw.sqlite"

# Encryption key path for stored datasource credentials.
# Default: $DATACLAW_DATA_DIR/secret.key
# export DATACLAW_SECRET_PATH="$HOME/.dataclaw/secret.key"

# DataClaw runtime configuration
#
# This file is documentation only. DataClaw does not auto-load dotenv files.
# Copy the lines you want into your shell profile or another sourced file,
# then remove the leading "# " before sourcing.

# Optional JSON config file. If unset, DataClaw reads
# $DATACLAW_DATA_DIR/config.json when that file exists.
# export DATACLAW_CONFIG_PATH="$HOME/.dataclaw/config.json"

# Base data directory for local DataClaw state.
# Default: ~/.dataclaw
# export DATACLAW_DATA_DIR="$HOME/.dataclaw"

# SQLite metadata database path.
# Default: $DATACLAW_DATA_DIR/dataclaw.sqlite
# export DATACLAW_DB_PATH="$HOME/.dataclaw/dataclaw.sqlite"

# Encryption key path for stored datasource credentials and derived signing keys.
# Default: $DATACLAW_DATA_DIR/secret.key
# export DATACLAW_SECRET_PATH="$HOME/.dataclaw/secret.key"

# slog level for structured logs on stderr.
# Accepted: debug, info, warn, warning, error (case-insensitive).
# Default: info
# export DATACLAW_LOG_LEVEL=info

# Admin listener bind address and preferred port. If the port is busy,
# DataClaw probes upward to the next free port.
# Defaults: 127.0.0.1:18790
# export DATACLAW_ADMIN_BIND_ADDR=127.0.0.1
# export DATACLAW_ADMIN_PORT=18790

# Admin advertised host/base URL for browser links. Use advertised_host for a
# host name/IP without scheme or port; use advertised_base_url for an absolute
# http(s) URL when reverse-proxy or TLS deployment needs exact control.
# export DATACLAW_ADMIN_ADVERTISED_HOST=127.0.0.1
# export DATACLAW_ADMIN_ADVERTISED_BASE_URL=https://dataclaw.example.com

# Admin TLS. Cert/key together make DataClaw serve TLS directly. TLS=true
# without cert/key only advertises https for reverse-proxy deployments.
# export DATACLAW_ADMIN_TLS=false
# export DATACLAW_ADMIN_TLS_CERT_FILE=/path/to/admin.crt
# export DATACLAW_ADMIN_TLS_KEY_FILE=/path/to/admin.key

# Admin password/session settings. If no password is configured, DataClaw uses
# the default password "admin" and logs a warning at startup.
# export DATACLAW_ADMIN_PASSWORD=change-me
# export DATACLAW_ADMIN_SESSION_TTL=12h
# export DATACLAW_ADMIN_SESSION_LONG_TTL=720h

# MCP listener bind address and preferred port. The MCP listener serves only
# MCP routes and remains loopback-only by default.
# Defaults: 127.0.0.1:18791
# export DATACLAW_MCP_BIND_ADDR=127.0.0.1
# export DATACLAW_MCP_PORT=18791

# MCP advertised host/base URL for generated agent MCP server manifests.
# export DATACLAW_MCP_ADVERTISED_HOST=127.0.0.1
# export DATACLAW_MCP_ADVERTISED_BASE_URL=https://mcp.dataclaw.example.com

# MCP TLS; semantics match the admin TLS settings above.
# export DATACLAW_MCP_TLS=false
# export DATACLAW_MCP_TLS_CERT_FILE=/path/to/mcp.crt
# export DATACLAW_MCP_TLS_KEY_FILE=/path/to/mcp.key

# Compatibility aliases retained for migration. These affect the admin listener
# only and emit deprecation warnings; prefer DATACLAW_ADMIN_*.
# export DATACLAW_BIND_ADDR=127.0.0.1
# export DATACLAW_PORT=18790
